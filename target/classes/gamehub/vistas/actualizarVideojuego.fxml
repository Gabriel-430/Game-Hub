<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gamehub.controladores.ActualizarVideojuegoController">
    <padding><Insets bottom="20.0" left="40.0" right="40.0" top="20.0"/></padding>
    <children>
        <Label fx:id="lbl_titulo_pantalla" styleClass="lbl-titulo" text="Actualizar Videojuego Existente" />
        
        <GridPane hgap="15" vgap="15" alignment="CENTER">
            <Label text="Título:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txt_titulo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Lanzamiento:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="dp_fecha" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Clasificación:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="cb_clasificacion" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            
            <Label text="Precio Base:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="txt_precioBase" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            
            <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <ComboBox fx:id="cb_estado" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            
            <Label text="Publisher:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cb_publisher" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            
            <Label text="Género:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cb_genero" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            
            <Label text="Plataforma:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <ComboBox fx:id="cb_plataforma" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
            
            <Label text="Precio Plataforma:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
            <TextField fx:id="txt_precioPlataforma" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
            
            <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <TextArea fx:id="txt_descripcion" prefRowCount="3" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="5"/>
        </GridPane>

        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20 0 0 0;">
            <Button styleClass="btn-accion" onAction="#actionGuardar" text="Guardar Cambios" />
            <Button styleClass="btn-cancelar" onAction="#actionCancelar" text="Cancelar / Volver" />
        </HBox>
    </children>
</VBox>