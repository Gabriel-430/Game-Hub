<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gamehub.controladores.ListarVideojuegoController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
    <children>
        <Label styleClass="lbl-titulo" text="Inventario de Videojuegos" />
        
        <TableView fx:id="tbl_datos" prefHeight="450" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="col_titulo" text="Título" prefWidth="250"/>
                <TableColumn fx:id="col_publisher" text="Publisher" prefWidth="200"/>
                <TableColumn fx:id="col_plataforma" text="Plataforma" prefWidth="200"/>
                <TableColumn fx:id="col_precio" text="Precio Base" prefWidth="150"/>
            </columns>
        </TableView>
        
        <HBox alignment="CENTER" spacing="20.0">
            <Button styleClass="btn-accion" onAction="#actionRefrescar" text="Refrescar Tabla" />
            <Button styleClass="btn-accion" onAction="#actionActualizar" text="Actualizar Seleccionado" />
            <Button styleClass="btn-cancelar" onAction="#actionEliminar" text="Eliminar Seleccionado" />
            <Button styleClass="btn-principal" style="-fx-background-color: #2b579a;" onAction="#actionRegresar" text="Regresar al Menú" />
        </HBox>
    </children>
</VBox>