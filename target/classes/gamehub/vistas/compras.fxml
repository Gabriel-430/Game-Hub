<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gamehub.controladores.ComprasController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
    <Label styleClass="lbl-titulo" text="Gestion de Compras" />
    <GridPane hgap="10" vgap="10" alignment="CENTER" style="-fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 10; -fx-padding: 20;">
        <Label text="ID Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txt_usuario" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="ID Videojuego:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txt_idVid" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="ID Plataforma:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="txt_idPlat" text="1" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Precio Final:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="txt_precio" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="Cantidad:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txt_cantidad" text="1" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Label text="Metodo Pago:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="cb_metodo" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox alignment="CENTER" spacing="20.0">
        <Button styleClass="btn-accion" onAction="#actionComprar" text="Ejecutar Compra" />
        <Button styleClass="btn-cancelar" onAction="#actionRegresar" text="Regresar al Menu" />
    </HBox>
</VBox>