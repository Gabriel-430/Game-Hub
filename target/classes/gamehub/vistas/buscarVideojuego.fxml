<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gamehub.controladores.BuscarVideojuegoController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
    <children>
        <Label styleClass="lbl-titulo" text="Búsqueda de Videojuegos" />
        
        <HBox alignment="CENTER" spacing="15.0">
            <Label text="Buscar por Título:" />
            <TextField fx:id="txt_busqueda" prefWidth="350" promptText="Ingresa el título..."/>
            <Button styleClass="btn-accion" onAction="#actionBuscar" text="Buscar" />
        </HBox>
        
        <TableView fx:id="tbl_resultados" prefHeight="400" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="col_titulo" text="Título" prefWidth="300"/>
                <TableColumn fx:id="col_genero" text="Género" prefWidth="200"/>
                <TableColumn fx:id="col_estado" text="Estado" prefWidth="150"/>
            </columns>
        </TableView>
        
        <Button styleClass="btn-cancelar" onAction="#actionRegresar" text="Regresar al Menú" />
    </children>
</VBox>