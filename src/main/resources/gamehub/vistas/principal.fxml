<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gamehub.controladores.PrincipalController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
    <children>
        <Label styleClass="lbl-titulo" text="GameHub - Gestión de Videojuegos" />
        <Button styleClass="btn-principal" onAction="#actionRegistrar" text="Registrar / Actualizar Videojuego" />
        <Button styleClass="btn-principal" onAction="#actionBuscar" text="Buscar Videojuego" />
        <Button styleClass="btn-principal" onAction="#actionListar" text="Listado General (CRUD)" />
        <Button styleClass="btn-cancelar" prefWidth="350" onAction="#actionSalir" text="Salir" />
    </children>
</VBox>
